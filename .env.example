# Backend base URL for Vite dev proxy.
# Used by `vite.config.ts` to proxy `/api`, `/oauth2`, and `/ws` during `npm run dev`.
VITE_BACKEND_PROXY_TARGET=http://localhost:8080

# Optional: set this to bypass Vite proxy and call backend directly from the browser.
# Leave empty for local development with proxy.
# VITE_API_BASE_URL=http://localhost:8080
